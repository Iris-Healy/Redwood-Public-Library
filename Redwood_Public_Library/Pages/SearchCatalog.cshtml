@page 
@model Redwood_Public_Library.Pages.SearchCatalogModel
@{
    ViewData["Title"] = "Catalog Search";
}

<h1>Search Our Catalog</h1>
<form method="post" class="row g-3 justify-content-center align-items-end">
    <div class="col-12 col-md-5">
        <input asp-for="SearchTerm" class="form-control" placeholder="Enter search term..." />
        <span asp-validation-for="SearchTerm" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-4">
        <label asp-for="SearchType" class="form-label"></label>
        <select asp-for="SearchType" class="form-select">
            <option value="Title">Title</option>
            <option value="ISBN">ISBN</option>
            <option value="Author">Author</option>
            <option value="Genre">Genre</option>
        </select>
        <span asp-validation-for="SearchType" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-2 text-center">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info mt-3">@Model.Message</div>
}

@if (Model.BookList != null && Model.BookList.Count > 0)
{
    <h2 class="mt-4">Search Results:</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>ISBN</th>
                <th>Author</th>
                <th>Language</th>
                <th>Availability</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.BookList)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.ISBN</td>
                    <td>@book.Author</td>
                    <td>@book.Language</td>
                    <td>@book.Availability</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (Model.BookList != null)
{
    <div class="alert alert-warning mt-3">No results found for "@Model.SearchTerm". Please try a different search term.</div>
}